<!doctype html>
<html lang="id">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>Login — situs jo</title>
	<style>
		/* style.css content (embedded as single-file deliverable) */
		:root{
			--bg:#0b1020;
			--glass: rgba(255,255,255,0.06);
			--accent1: #7b61ff; /* neon pastel gradient */
			--accent2: #169cad;
			--accent3: #dd1d9a;
		}
		*{box-sizing:border-box}
		html,body{height:100%}
		body{
			margin:0; font-family:Inter,system-ui,Segoe UI,Roboto,Helvetica,Arial,sans-serif;
			background: radial-gradient(1200px 600px at 10% 10%, rgba(123,97,255,0.12), transparent 8%),
									radial-gradient(900px 400px at 90% 90%, rgba(0,224,255,0.06), transparent 6%),
									var(--bg);
			color:#eaf2ff;
			display:flex; align-items:center; justify-content:center; padding:32px;
		}
		.container{width:100%;max-width:980px;display:grid;grid-template-columns:1fr 420px;gap:40px;align-items:center}
		@media (max-width:880px){.container{grid-template-columns:1fr;gap:24px;padding:12px}}

		.hero{
			padding:36px;border-radius:16px;backdrop-filter: blur(8px) saturate(120%);
			background: linear-gradient(135deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
			border:1px solid rgba(255,255,255,0.04);
		}
		.hero h1{margin:0 0 12px;font-size:28px;line-height:1}
		.hero p{margin:0;color:#caddffcc}

		/* Glassmorphism login form */
		.login{
			padding:28px;border-radius:14px;min-height:320px;
			background: linear-gradient(135deg, var(--glass), rgba(255,255,255,0.02));
			border:1px solid rgba(255,255,255,0.06);
			box-shadow: 0 8px 30px rgba(2,6,23,0.6);
			display:flex;flex-direction:column;gap:18px;
		}
		.brand{display:flex;gap:12px;align-items:center}
		.logo{width:44px;height:44px;border-radius:10px;background:linear-gradient(135deg,var(--accent1),var(--accent2));box-shadow:0 6px 18px rgba(0,0,0,0.4)}
		.login h2{margin:4px 0 0;font-size:20px}

		form{display:flex;flex-direction:column;gap:12px}
		.field{position:relative}
		label{display:block;font-size:13px;color:#cbe7ffcc;margin-bottom:6px}
		input[type="text"], input[type="password"]{
			width:100%;padding:12px 14px;border-radius:10px;border:1px solid transparent;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
			color:inherit;outline:none;transition:box-shadow .22s ease, border-color .18s ease, transform .18s ease;
			font-size:15px;
		}
		input::placeholder{color:#9fbfe6aa}
		input:focus{
			box-shadow: 0 6px 26px rgba(123,97,255,0.12), 0 2px 8px rgba(0,224,255,0.06);
			border-color: rgba(123,97,255,0.45);
			transform: translateY(-1px);
		}

		.actions{display:flex;flex-direction:column;gap:10px;margin-top:6px}
		.btn{
			display:inline-flex;align-items:center;justify-content:center;padding:12px 14px;border-radius:10px;border:0;cursor:pointer;
			background:linear-gradient(90deg,var(--accent1),var(--accent2));color:#041021;font-weight:600;font-size:15px;transition:transform .14s ease, box-shadow .14s ease, filter .14s ease;
			box-shadow: 0 8px 24px rgba(123,97,255,0.12);
		}
		.btn:hover{transform:translateY(-3px);filter:brightness(1.06)}
		.btn:active{transform:translateY(-1px)}

		.linkrow{display:flex;justify-content:space-between;align-items:center;font-size:14px}
		.link{color:var(--accent3);text-decoration:none}
		.secondary{
			background:transparent;color:var(--accent2);border:1px solid rgba(0,224,255,0.12);box-shadow:none;font-weight:600
		}

		.footer{text-align:center;margin-top:8px;color:#bcd9ff88;font-size:13px}
	</style>
</head>
<body>
	<div class="container">
		<div class="hero">
			<h1>Selamat Datang</h1>
			<p>Masuk untuk melanjutkan ke dashboard. Gunakan akun Anda yang terdaftar.</p>
			<div style="height:24px"></div>
			<p style="font-size:13px;color:#9fbfe6aa">Tips: Gunakan email atau username pada kolom Email/Username.</p>
		</div>

		<main class="login" role="main" aria-labelledby="login-title">
			<div class="brand">
				<div class="logo" aria-hidden="true"></div>
				<div>
					<h2 id="login-title">Masuk ke Akun</h2>
					<div style="font-size:13px;color:#caddffcc">Aman dan cepat</div>
				</div>
			</div>

			<form id="loginForm" novalidate>
				<div class="field">
					<label for="user">Email / Username</label>
					<input id="user" name="user" type="text" placeholder="Email atau username" required autocomplete="username">
				</div>

				<div class="field">
					<label for="pass">Password</label>
					<input id="pass" name="pass" type="password" placeholder="Masukkan password" required autocomplete="current-password">
				</div>

				<div class="linkrow">
					<a href="#" class="link" id="forgot">Lupa Password?</a>
					<a href="#" class="link">Daftar Akun Baru</a>
				</div>

				<div class="actions">
					<button class="btn" type="submit">Login</button>
					<button class="btn secondary" type="button" id="demoBtn">Masuk Sebagai Tamu</button>
				</div>
			</form>

			<div class="footer">Dengan masuk, Anda menyetujui ketentuan layanan kami.</div>
		</main>
	</div>

	<script>
		// script.js content (embedded)
		(function(){
			const form = document.getElementById('loginForm');
			form.addEventListener('submit', function(e){
				e.preventDefault();
				const u = form.user.value.trim();
				const p = form.pass.value.trim();
				if(!u || !p){
					// simple client validation
					alert('Mohon isi Email/Username dan Password.');
					return;
				}
				// Placeholder interaction: animate button then simulate success
				const btn = form.querySelector('.btn');
				btn.disabled = true; btn.textContent = 'Memproses...';
				setTimeout(()=>{ btn.disabled=false; btn.textContent='Login'; alert('Berhasil (demo).'); }, 900);
			});

			document.getElementById('demoBtn').addEventListener('click', function(){
				form.user.value = 'guest@example.com'; form.pass.value = 'guest';
			});

			// tiny accessibility: handle Enter in inputs
			['user','pass'].forEach(id=>{
				const el = document.getElementById(id);
				el.addEventListener('keydown', function(e){ if(e.key==='Enter'){ form.dispatchEvent(new Event('submit',{cancelable:true})); }});
			});
		})();
	</script>
</body>
</html>
